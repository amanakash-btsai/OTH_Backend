{
  "name": "oth-backend",
  "version": "1.0.0",
  "description": "EQC Asset Management Platform — Backend API",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --transpile-only --respawn -r tsconfig-paths/register src/server.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:coverage": "jest --coverage",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.8.0",
    "@azure/storage-blob": "^12.24.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/client": "^5.22.0",
    "applicationinsights": "^3.3.1",
    "bcryptjs": "^2.4.3",
    "botbuilder": "^4.23.3",
    "bullmq": "^5.13.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "nodemailer": "^6.9.15",
    "openai": "^4.67.3",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^6.4.16",
    "@types/pdfkit": "^0.13.6",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
